<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/favorites.css">
</head>
<body class="fav-page">
  <header class="fav-header">
    <a href="/" class="fav-back">← На главную</a>
    <h1>Избранное</h1>
    <p class="fav-count">
      <% if (favorites.length === 0) { %>
        пока пусто
      <% } else { %>
        <%= favorites.length %> <%= favorites.length === 1 ? 'видео' : 'видео сохранено' %>
      <% } %>
    </p>
  </header>

  <form action="/favorites/add" method="POST" class="fav-form">
    <input type="url" name="url" placeholder="Вставьте ссылку на видео…" required>
    <input type="text" name="title" placeholder="Название (необязательно)">
    <button type="submit">
      <span>Сохранить</span>
    </button>
  </form>

  <% if (favorites.length === 0) { %>
    <div class="fav-empty">
      <p>Здесь появятся видео, которые вы захотите посмотреть позже.</p>
      <p class="fav-empty-sub">Вставьте ссылку выше — YouTube, Vimeo, VK Video, RuTube и другие.</p>
    </div>
  <% } else { %>
    <div class="fav-grid">
      <% favorites.forEach((f, i) => { %>
        <div class="fav-card" style="--i: <%= i %>">
          <div class="fav-video">
            <% if (f.embeddable) { %>
              <button class="fav-play" data-embed="<%= f.embedUrl %>" data-title="<%= (f.title || 'Видео').replace(/"/g, '&quot;') %>" data-fav-id="<%= f.id %>" aria-label="Воспроизвести видео">
                <span class="fav-play-icon">▶</span>
                <span class="fav-play-label">Смотреть</span>
              </button>
            <% } else { %>
              <a href="<%= f.url %>" target="_blank" class="fav-noembed">
                <span class="fav-noembed-icon">▶</span>
                <% if (f.type === 'vk') { %>
                  <span>Открыть в VK Видео</span>
                <% } else { %>
                  <span>Открыть видео</span>
                <% } %>
              </a>
            <% } %>
          </div>
          <div class="fav-meta">
            <h3><%= f.title || 'Без названия' %></h3>
            <div class="fav-actions">
              <span class="fav-date"><%= f.date %></span>
              <div class="fav-links">
                <a href="<%= f.url %>" target="_blank" class="fav-link">Оригинал</a>
                <form action="/favorites/<%= f.id %>/delete" method="POST">
                  <button type="submit" class="fav-delete" aria-label="Удалить из избранного">Удалить</button>
                </form>
              </div>
            </div>
            <% if (f.comments.length > 0) { %>
              <div class="fav-comment-count">💬 <%= f.comments.length %></div>
            <% } %>
          </div>
        </div>

        <!-- Скрытый шаблон комментариев для модалки -->
        <template class="fav-comments-template" data-fav-id="<%= f.id %>">
          <div class="fav-comments">
            <% if (f.comments.length > 0) { %>
              <ul class="fav-comments-list">
                <% f.comments.forEach(c => { %>
                  <li>
                    <div class="fav-comment-head">
                      <strong><%= c.author %></strong>
                      <span class="fav-comment-date"><%= c.date %></span>
                    </div>
                    <p class="fav-comment-text"><%= c.text %></p>
                    <form action="/comments/<%= c.id %>/delete" method="POST" class="fav-comment-delete-form">
                      <button type="submit" class="fav-comment-delete">Удалить</button>
                    </form>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="fav-comments-empty">Пока нет комментариев. Будьте первым!</p>
            <% } %>

            <form action="/favorites/<%= f.id %>/comments/add" method="POST" class="fav-comment-form">
              <input type="text" name="author" placeholder="Ваше имя">
              <input type="text" name="text" placeholder="Напишите комментарий..." required>
              <button type="submit">Отправить</button>
            </form>
          </div>
        </template>
      <% }) %>
    </div>
  <% } %>

  <!-- Модальное окно для просмотра видео -->
  <div class="fav-modal" id="fav-modal" aria-hidden="true">
    <div class="fav-modal-backdrop" data-close></div>
    <div class="fav-modal-content">
      <div class="fav-modal-header">
        <span class="fav-modal-title" id="fav-modal-title"></span>
        <button class="fav-modal-close" data-close aria-label="Закрыть">✕</button>
      </div>
      <div class="fav-modal-video">
        <iframe id="fav-modal-iframe" src="" frameborder="0" allowfullscreen allow="autoplay; fullscreen"></iframe>
      </div>
      <div class="fav-modal-comments" id="fav-modal-comments"></div>
    </div>
  </div>

 <script>
  (function () {
    const modal = document.getElementById('fav-modal');
    const iframe = document.getElementById('fav-modal-iframe');
    const titleEl = document.getElementById('fav-modal-title');
    const commentsContainer = document.getElementById('fav-modal-comments');

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function renderComment(c) {
      const li = document.createElement('li');
      li.dataset.commentId = c.id;
      li.innerHTML = `
        <div class="fav-comment-head">
          <strong>${escapeHtml(c.author)}</strong>
          <span class="fav-comment-date">${escapeHtml(c.date)}</span>
        </div>
        <p class="fav-comment-text">${escapeHtml(c.text)}</p>
        <form class="fav-comment-delete-form" data-comment-id="${c.id}">
          <button type="button" class="fav-comment-delete">Удалить</button>
        </form>
      `;
      return li;
    }

    function bindDeleteButtons() {
      commentsContainer.querySelectorAll('.fav-comment-delete-form').forEach(form => {
        form.addEventListener('submit', handleDelete);
        form.querySelector('button').addEventListener('click', (e) => {
          e.preventDefault();
          handleDelete({ target: form });
        });
      });
    }

    async function handleDelete(e) {
      const form = e.target;
      const commentId = form.dataset.commentId;

      try {
        await fetch(`/comments/${commentId}/delete`, { method: 'POST' });
        const li = form.closest('li');
        li.remove();

        const list = commentsContainer.querySelector('.fav-comments-list');
        if (list && list.children.length === 0) {
          const empty = document.createElement('p');
          empty.className = 'fav-comments-empty';
          empty.textContent = 'Пока нет комментариев. Будьте первым!';
          list.replaceWith(empty);
        }
      } catch (err) {
        console.error('Ошибка удаления комментария', err);
      }
    }

    function openModal(embedUrl, title, favId) {
      iframe.src = embedUrl;
      titleEl.textContent = title || '';

      commentsContainer.innerHTML = '';
      const template = document.querySelector(`.fav-comments-template[data-fav-id="${favId}"]`);
      if (template) {
        commentsContainer.appendChild(template.content.cloneNode(true));
        bindDeleteButtons();

        const form = commentsContainer.querySelector('.fav-comment-form');
        form.dataset.favId = favId;
        form.addEventListener('submit', handleAddComment);
      }

      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    async function handleAddComment(e) {
      e.preventDefault();
      const form = e.target;
      const favId = form.dataset.favId;
      const authorInput = form.querySelector('input[name="author"]');
      const textInput = form.querySelector('input[name="text"]');

      const text = textInput.value.trim();
      if (!text) return;

      try {
        const res = await fetch(`/favorites/${favId}/comments/add`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ author: authorInput.value, text: text })
        });

        if (!res.ok) return;
        const comment = await res.json();

        let list = commentsContainer.querySelector('.fav-comments-list');
        if (!list) {
          const empty = commentsContainer.querySelector('.fav-comments-empty');
          list = document.createElement('ul');
          list.className = 'fav-comments-list';
          if (empty) empty.replaceWith(list);
          else commentsContainer.insertBefore(list, form);
        }

        list.appendChild(renderComment(comment));

        textInput.value = '';
        authorInput.value = '';
      } catch (err) {
        console.error('Ошибка отправки комментария', err);
      }
    }

    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      iframe.src = '';
      commentsContainer.innerHTML = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.fav-play').forEach(btn => {
      btn.addEventListener('click', () => {
        openModal(btn.dataset.embed, btn.dataset.title, btn.dataset.favId);
      });
    });

    modal.querySelectorAll('[data-close]').forEach(el => {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) {
        closeModal();
      }
    });
  })();
</script>
</body>
</html>