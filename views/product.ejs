<%- include('partials/header') %>

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">
  <a href="/products" class="d-inline-block mb-4">← Назад в каталог</a>

  <div class="row">
    <div class="col-md-5">
      <img src="<%= product.image %>" alt="<%= product.name %>" class="img-fluid" style="max-height: 350px; object-fit: contain;">
    </div>
    <div class="col-md-7">
      <h1><%= product.name %></h1>
      <p class="mt-3"><%= product.description %></p>
      <p class="mt-3"><strong style="font-size: 1.5rem;"><%= product.price %> руб.</strong></p>

      <form action="/cart/add/<%= product.id %>" method="POST" class="mt-4">
        <button type="submit" class="boxed-btn3">Добавить в корзину</button>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>